{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SQLite CVE enriched result schema",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "ID",
      "vendor_release_date",
      "vendor_release_url",
      "url",
      "published_date",
      "updated_date",
      "description",
      "cvss_list",
      "cpe_list",
      "cwe"
    ],
    "properties": {
      "ID": {
        "type": "string",
        "pattern": "^CVE-\\d{4}-\\d+$",
        "minLength": 1
      },
      "vendor_release_date": {
        "type": "string",
        "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
        "minLength": 10
      },
      "vendor_release_url": {
        "type": "string",
        "format": "uri",
        "minLength": 1
      },
      "url": {
        "type": "string",
        "format": "uri",
        "minLength": 1
      },
      "published_date": {
        "type": "string",
        "minLength": 1
      },
      "updated_date": {
        "type": "string",
        "minLength": 1
      },
      "description": {
        "type": "string",
        "minLength": 1
      },
      "cvss_list": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["version", "score", "vector", "severity"],
          "properties": {
            "version": {
              "type": "string",
              "minLength": 1
            },
            "score": {},
            "vector": {
              "type": "string",
              "minLength": 1
            },
            "severity": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      },
      "cpe_list": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "cwe": {
        "type": "object",
        "minProperties": 1,
        "patternProperties": {
          "^CWE-\\d+$": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "description"],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "additionalProperties": false
      }
    }
  }
}
